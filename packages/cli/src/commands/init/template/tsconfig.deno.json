{
   "compilerOptions": {
      "target": "ES2022",
      "module": "ES2022",
      "moduleResolution": "Bundler",
      "lib": [
         "ES2022",
         "DOM"
      ],
      "types": [],
      "outDir": "dist",
      "rootDir": "src",
      "baseUrl": ".",
      "paths": {},
      "strict": true,
      "skipLibCheck": true,
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true
   },
   "include": [
      "src"
   ],
   "exclude": [
      "dist"
   ]
}